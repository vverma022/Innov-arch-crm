generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id               String   @id @default(uuid()) @db.Uuid
  email            String   @unique
  name             String
  avatarUrl        String?
  emailVerified    Boolean? @default(false)
  rolePermissionId String   @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userAuth       UserAuth?
  rolePermission RolePermission @relation(fields: [rolePermissionId], references: [id])
  chats          Chat[]
  sessions       Session[]

  @@index([email])
  @@map("users")
}

/** Better Auth session table */
model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

/** Better Auth verification table */
model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model RolePermission {
  id          String   @id @default(uuid()) @db.Uuid
  role        UserRole
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users User[]

  @@map("role_permissions")
}

/** Credential storage for Better Auth (email/password). Maps to account model. */
model UserAuth {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  accountId  String
  providerId String   @default("credential")
  password   String
  isDeleted  Boolean  @default(false)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("user_auths")
}

model Chat {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @db.Uuid
  title    String  @default("New Chat")
  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("chats")
}

model ChatMessage {
  id          String   @id @default(uuid()) @db.Uuid
  chatId      String   @db.Uuid
  role        String
  parts       Json?
  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([updatedAt])
  @@map("chat_messages")
}
